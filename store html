<script>
// ═══════════════════════════════════════════
// CANVAS BACKGROUND — Interactive Dot Grid
// ═══════════════════════════════════════════
const canvas = document.getElementById('bgCanvas');
const ctx = canvas.getContext('2d');
let mouse = {x:-9999,y:-9999};
let dots = [];
const SPACING = 38, DOT_R = 1.2, INFLUENCE = 130, BASE_A = 0.06, PEAK_A = 0.7;

function initDots(){
  dots = [];
  for(let r = 0; r * SPACING <= canvas.height + SPACING; r++){
    for(let c = 0; c * SPACING <= canvas.width + SPACING; c++){
      dots.push({ox:c*SPACING, oy:r*SPACING, x:c*SPACING, y:r*SPACING});
    }
  }
}
function animCanvas(){
  requestAnimationFrame(animCanvas);
  ctx.clearRect(0,0,canvas.width,canvas.height);
  dots.forEach(d=>{
    const dx = mouse.x - d.ox, dy = mouse.y - d.oy;
    const dist = Math.sqrt(dx*dx + dy*dy);
    const inf = Math.max(0, 1 - dist / INFLUENCE);
    d.x += (d.ox + dx * inf * 0.18 - d.x) * 0.1;
    d.y += (d.oy + dy * inf * 0.18 - d.y) * 0.1;
    const a = BASE_A + inf * (PEAK_A - BASE_A);
    const r = DOT_R + inf * 1.8;
    ctx.beginPath();
    ctx.arc(d.x, d.y, r, 0, Math.PI*2);
    ctx.fillStyle = `rgba(0,212,255,${a})`;
    ctx.fill();
  });
}
function resizeCanvas(){
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
  initDots();
}
window.addEventListener('resize', resizeCanvas);
resizeCanvas();
animCanvas();

// ═══════════════════════════════════════════
// SPOTLIGHT + CURSOR
// ═══════════════════════════════════════════
const spotlight = document.getElementById('spotlight');
const cursorDot = document.getElementById('cursorDot');
const cursorRing = document.getElementById('cursorRing');
let tx=0,ty=0,rx=0,ry=0;
function animCursor(){
  requestAnimationFrame(animCursor);
  rx += (tx - rx) * 0.1;
  ry += (ty - ry) * 0.1;
  cursorRing.style.transform = `translate(calc(${rx}px - 50%), calc(${ry}px - 50%))`;
}
