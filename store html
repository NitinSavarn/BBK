// ═══════════════════════════════════════════
// SCROLL REVEAL
// ═══════════════════════════════════════════
function initReveal(){
  const els = document.querySelectorAll('.reveal:not(.vis),.reveal-l:not(.vis),.reveal-r:not(.vis)');
  const obs = new IntersectionObserver(entries=>{
    entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('vis');obs.unobserve(e.target);}});
  },{threshold:.08});
  els.forEach(el=>obs.observe(el));
}

// ═══════════════════════════════════════════
// ANIMATED COUNTER
// ═══════════════════════════════════════════
function animateCounter(el, target, suffix=''){
  let start = 0;
  const duration = 2000, step = 16;
  const inc = target / (duration / step);
  const timer = setInterval(()=>{
    start += inc;
    if(start >= target){start = target; clearInterval(timer);}
    el.textContent = Math.round(start).toLocaleString() + suffix;
  }, step);
}
const counterObs = new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      const el = e.target.querySelector('.stat-val');
      if(el){
        const target = parseInt(el.dataset.target);
        const suffix = el.closest('.stat-val')?.dataset?.suffix || (target===99?'%':target>=100?'+':'');
        animateCounter(el, target, target===99?'%':target>=100?'+':'');
      }
      counterObs.unobserve(e.target);
    }
  });
},{threshold:.5});
document.querySelectorAll('.stats-inner > div').forEach(el=>counterObs.observe(el));

