// ═══════════════════════════════════════════
// 3D TILT ON PRODUCT CARDS
// ═══════════════════════════════════════════
function initTilt(){
  document.querySelectorAll('.prod-card,.cat-card').forEach(card=>{
    card.addEventListener('mousemove',e=>{
      const r = card.getBoundingClientRect();
      const x = e.clientX - r.left, y = e.clientY - r.top;
      const cx = r.width/2, cy = r.height/2;
      const rx2 = (y-cy)/cy * -8;
      const ry2 = (x-cx)/cx * 8;
      card.style.transform = `perspective(800px) rotateX(${rx2}deg) rotateY(${ry2}deg) translateY(-6px)`;
      card.style.boxShadow = `0 25px 50px rgba(0,0,0,.4), 0 0 30px rgba(0,212,255,0.08)`;
    });
    card.addEventListener('mouseleave',()=>{
      card.style.transform = '';
      card.style.boxShadow = '';
    });
  });
}

