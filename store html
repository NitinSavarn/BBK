<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ZIPD — Drop Your Style</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Manrope:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#030712;--bg2:#060f1f;--bg3:#0a1628;--bg4:#0d1f3c;
  --cyan:#00D4FF;--mint:#00FFD1;--sky:#60A5FA;--ice:#BAE6FD;
  --text:#E0F2FE;--muted:#4B7499;--muted2:#1E3A5F;
  --border:rgba(0,212,255,0.1);--border2:rgba(0,212,255,0.22);
  --glow:rgba(0,212,255,0.12);--glow2:rgba(0,255,209,0.1);
  --card:rgba(10,22,40,0.85);
  --r8:8px;--r12:12px;--r16:16px;--r24:24px;
}
html{scroll-behavior:smooth}
body{
  font-family:'Manrope',sans-serif;background:var(--bg);color:var(--text);
  overflow-x:hidden;cursor:none;min-height:100vh
}

/* ── CANVAS + CURSOR + SPOTLIGHT ── */
#bgCanvas{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none}
#spotlight{position:fixed;top:0;left:0;width:100%;height:100%;z-index:1;pointer-events:none;transition:opacity .3s}
#cursorDot{
  position:fixed;top:0;left:0;width:5px;height:5px;
  background:var(--cyan);border-radius:50%;pointer-events:none;
  z-index:9999;transform:translate(-50%,-50%);
  transition:width .15s,height .15s,background .15s;
  will-change:transform;box-shadow:0 0 6px var(--cyan)
}
#cursorRing{
  position:fixed;top:0;left:0;width:26px;height:26px;
  border:1px solid rgba(0,212,255,0.35);border-radius:50%;
  pointer-events:none;z-index:9998;transform:translate(-50%,-50%);
  will-change:transform;transition:width .25s,height .25s,border-color .25s
}
#cursorDot.hov{width:8px;height:8px;background:var(--mint)}
#cursorRing.hov{width:44px;height:44px;border-color:rgba(0,255,209,0.6)}
body *{cursor:none!important}

/* ── APP WRAPPER ── */
#app{position:relative;z-index:2;padding-top:70px;min-height:100vh}
.page{display:none;animation:none}
.page.active{display:block;animation:pgIn .4s cubic-bezier(.4,0,.2,1) forwards}
@keyframes pgIn{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:1000;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 2.5rem;height:70px;
  background:rgba(3,7,18,0.8);backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border)
}
.nav-logo{
  font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800;
  background:linear-gradient(90deg,var(--cyan),var(--mint));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;letter-spacing:.05em;cursor:pointer
}
.nav-links{display:flex;align-items:center;gap:.25rem}
.nlink{
  background:none;border:none;color:var(--muted);
  font-family:'Manrope',sans-serif;font-size:.82rem;font-weight:500;
  letter-spacing:.04em;padding:.45rem .85rem;border-radius:var(--r8);
  cursor:pointer;transition:all .2s;position:relative
}
.nlink:hover,.nlink.active{color:var(--text);background:rgba(0,212,255,0.06)}
.nlink.active::after{
  content:'';position:absolute;bottom:2px;left:50%;transform:translateX(-50%);
  width:18px;height:2px;background:var(--cyan);border-radius:2px
}
.nav-right{display:flex;align-items:center;gap:.6rem}
.three-dots{
  position:relative;background:none;border:1px solid var(--border2);
  color:var(--muted);width:36px;height:36px;border-radius:var(--r8);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;transition:all .2s;font-size:1.1rem
}
.three-dots:hover{background:var(--glow);color:var(--cyan);border-color:var(--cyan)}
.dots-dropdown{
  position:absolute;top:calc(100% + 8px);right:0;
  background:rgba(6,15,31,0.95);backdrop-filter:blur(20px);
  border:1px solid var(--border2);border-radius:var(--r12);padding:.5rem;
  min-width:160px;display:none;z-index:100
}
.dots-dropdown.open{display:block;animation:dropIn .2s ease}
@keyframes dropIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
.dd-item{
  width:100%;background:none;border:none;color:var(--muted);
  font-family:'Manrope',sans-serif;font-size:.82rem;font-weight:500;
  text-align:left;padding:.6rem .85rem;border-radius:var(--r8);
  cursor:pointer;display:flex;align-items:center;gap:.65rem;transition:all .2s
}
.dd-item:hover{background:var(--glow);color:var(--text)}
.btn-ghost-nav{
  background:none;border:1px solid var(--border2);color:var(--text);
  font-family:'Manrope',sans-serif;font-size:.8rem;font-weight:600;
  padding:.45rem 1.1rem;border-radius:var(--r8);cursor:pointer;
  transition:all .2s;white-space:nowrap
}
.btn-ghost-nav:hover{border-color:var(--cyan);color:var(--cyan);background:var(--glow)}
.btn-solid-nav{
  background:linear-gradient(135deg,var(--cyan),var(--mint));
  border:none;color:#000;font-family:'Manrope',sans-serif;font-size:.8rem;
  font-weight:700;padding:.45rem 1.2rem;border-radius:var(--r8);
  cursor:pointer;transition:all .2s;white-space:nowrap
}
.btn-solid-nav:hover{opacity:.85;transform:translateY(-1px);box-shadow:0 4px 20px rgba(0,212,255,.3)}
.icon-btn{
  background:none;border:1px solid var(--border);width:36px;height:36px;
  border-radius:var(--r8);display:flex;align-items:center;justify-content:center;
  cursor:pointer;transition:all .2s;color:var(--muted);font-size:1rem;position:relative
}
.icon-btn:hover{border-color:var(--cyan);color:var(--cyan);background:var(--glow)}
.cart-badge{
  position:absolute;top:-5px;right:-5px;width:16px;height:16px;
  background:var(--cyan);color:#000;font-size:.6rem;font-weight:700;
  border-radius:50%;display:flex;align-items:center;justify-content:center;
  display:none
}
.cart-badge.show{display:flex}

/* ── SHARED HELPERS ── */
.btn-primary{
  background:linear-gradient(135deg,var(--cyan),var(--mint));
  border:none;color:#000;font-family:'Manrope',sans-serif;
  font-size:.85rem;font-weight:700;letter-spacing:.03em;
  padding:.85rem 2rem;border-radius:var(--r12);cursor:pointer;
  transition:all .25s;display:inline-block;text-decoration:none
}
.btn-primary:hover{opacity:.88;transform:translateY(-2px);box-shadow:0 8px 30px rgba(0,212,255,.25)}
.btn-outline{
  background:transparent;border:1px solid var(--border2);color:var(--text);
  font-family:'Manrope',sans-serif;font-size:.85rem;font-weight:600;
  padding:.85rem 2rem;border-radius:var(--r12);cursor:pointer;
  transition:all .25s;display:inline-block
}
.btn-outline:hover{border-color:var(--cyan);color:var(--cyan);background:var(--glow)}
.tag{
  font-size:.68rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;
  color:var(--cyan);margin-bottom:.65rem
}
.h1{
  font-family:'Syne',sans-serif;font-size:clamp(3rem,7vw,6.5rem);
  font-weight:800;line-height:.96;letter-spacing:-.02em;margin-bottom:1.25rem
}
.h2{
  font-family:'Syne',sans-serif;font-size:clamp(2rem,4.5vw,3.5rem);
  font-weight:700;line-height:1;letter-spacing:-.02em;margin-bottom:.85rem
}
.h3{font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:700;letter-spacing:-.01em;margin-bottom:.6rem}
.sub{font-size:.95rem;color:var(--muted);line-height:1.75;font-weight:400;max-width:520px}
.grad{background:linear-gradient(90deg,var(--cyan),var(--mint));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.card-glass{
  background:var(--card);backdrop-filter:blur(20px);
  border:1px solid var(--border);border-radius:var(--r16);
  transition:all .3s cubic-bezier(.4,0,.2,1)
}
.card-glass:hover{border-color:var(--border2);box-shadow:0 0 30px rgba(0,212,255,.07)}
.section{padding:6rem 2.5rem}
.container{max-width:1240px;margin:0 auto}
.form-group{display:flex;flex-direction:column;gap:.45rem;margin-bottom:1.1rem}
.form-label{font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
.form-input{
  background:rgba(10,22,40,.7);border:1px solid var(--border2);
  color:var(--text);font-family:'Manrope',sans-serif;font-size:.9rem;
  padding:.8rem 1rem;border-radius:var(--r8);outline:none;
  transition:border-color .2s,box-shadow .2s;width:100%
}
.form-input:focus{border-color:var(--cyan);box-shadow:0 0 0 3px rgba(0,212,255,.1)}
.form-input::placeholder{color:var(--muted2)}
.form-select{
  background:rgba(10,22,40,.7);border:1px solid var(--border2);
  color:var(--text);font-family:'Manrope',sans-serif;font-size:.9rem;
  padding:.8rem 1rem;border-radius:var(--r8);outline:none;width:100%;
  -webkit-appearance:none;cursor:pointer;transition:border-color .2s
}
.form-select:focus{border-color:var(--cyan)}
.badge{
  display:inline-block;font-size:.62rem;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;padding:.25rem .6rem;
  border-radius:6px;
}
.badge-cyan{background:rgba(0,212,255,.15);color:var(--cyan)}
.badge-mint{background:rgba(0,255,209,.12);color:var(--mint)}
.badge-hot{background:rgba(255,120,50,.15);color:#FF8C42}
.badge-lim{background:rgba(192,132,252,.15);color:#C084FC}
.divider{height:1px;background:var(--border);margin:1.75rem 0}

/* reveal animations */
.reveal{opacity:0;transform:translateY(28px);transition:opacity .7s cubic-bezier(.4,0,.2,1),transform .7s cubic-bezier(.4,0,.2,1)}
.reveal.vis{opacity:1;transform:none}
.reveal-l{opacity:0;transform:translateX(-28px);transition:opacity .7s cubic-bezier(.4,0,.2,1),transform .7s cubic-bezier(.4,0,.2,1)}
.reveal-l.vis{opacity:1;transform:none}
.reveal-r{opacity:0;transform:translateX(28px);transition:opacity .7s cubic-bezier(.4,0,.2,1),transform .7s cubic-bezier(.4,0,.2,1)}
.reveal-r.vis{opacity:1;transform:none}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}.d4{transition-delay:.4s}.d5{transition-delay:.5s}

/* letter anim */
.letter{display:inline-block;opacity:0;transform:translateY(60px) rotateX(-40deg);transform-origin:bottom;transition:opacity .6s cubic-bezier(.4,0,.2,1),transform .6s cubic-bezier(.4,0,.2,1)}
.letter.vis{opacity:1;transform:none}

/* ── HOME PAGE ── */
.hero{
  min-height:calc(100vh - 70px);display:flex;flex-direction:column;
  justify-content:center;padding:4rem 2.5rem 3rem;
  position:relative;overflow:hidden
}
.hero-orb1{
  position:absolute;top:-10%;right:-5%;width:700px;height:700px;
  background:radial-gradient(circle,rgba(0,212,255,.06) 0%,transparent 65%);
  pointer-events:none;filter:blur(20px);animation:orbFloat 8s ease-in-out infinite
}
.hero-orb2{
  position:absolute;bottom:-20%;left:-10%;width:500px;height:500px;
  background:radial-gradient(circle,rgba(0,255,209,.05) 0%,transparent 65%);
  pointer-events:none;filter:blur(30px);animation:orbFloat 12s ease-in-out infinite reverse
}
@keyframes orbFloat{0%,100%{transform:translate(0,0)}50%{transform:translate(20px,-20px)}}
.hero-inner{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;max-width:1240px;margin:0 auto;width:100%}
.hero-eyebrow{
  display:inline-flex;align-items:center;gap:.6rem;
  background:rgba(0,212,255,.08);border:1px solid var(--border2);
  border-radius:20px;padding:.35rem .9rem;font-size:.72rem;
  font-weight:700;letter-spacing:.12em;text-transform:uppercase;
  color:var(--cyan);margin-bottom:1.5rem
}
.hero-eyebrow::before{content:'';width:6px;height:6px;background:var(--cyan);border-radius:50%;animation:pulse 1.8s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.7)}}
.hero-title-wrap{overflow:hidden;perspective:600px}
.hero-cta-row{display:flex;align-items:center;gap:1rem;margin-top:2.5rem;flex-wrap:wrap}
.hero-scroll{display:flex;align-items:center;gap:.6rem;font-size:.72rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-top:3rem}
.scroll-anim{width:20px;height:32px;border:1px solid var(--border2);border-radius:10px;display:flex;align-items:flex-start;justify-content:center;padding:5px}
.scroll-dot{width:3px;height:6px;background:var(--cyan);border-radius:2px;animation:scrollDot 1.6s ease-in-out infinite}
@keyframes scrollDot{0%,100%{transform:translateY(0);opacity:1}60%{transform:translateY(8px);opacity:.3}}

/* Hero visual - floating product cards */
.hero-visual{position:relative;height:480px;perspective:800px}
.float-card{
  position:absolute;background:var(--card);backdrop-filter:blur(20px);
  border:1px solid var(--border2);border-radius:var(--r16);padding:1.5rem;
  width:200px;transition:transform .3s ease;
  box-shadow:0 20px 60px rgba(0,0,0,.4)
}
.float-card:nth-child(1){top:40px;right:80px;transform:rotateY(-12deg) rotateX(4deg);animation:fc1 6s ease-in-out infinite}
.float-card:nth-child(2){top:160px;right:240px;transform:rotateY(-8deg) rotateX(2deg);animation:fc2 8s ease-in-out infinite}
.float-card:nth-child(3){top:280px;right:50px;transform:rotateY(-15deg) rotateX(-3deg);animation:fc3 7s ease-in-out infinite}
@keyframes fc1{0%,100%{transform:rotateY(-12deg) rotateX(4deg) translateY(0)}50%{transform:rotateY(-12deg) rotateX(4deg) translateY(-12px)}}
@keyframes fc2{0%,100%{transform:rotateY(-8deg) rotateX(2deg) translateY(0)}50%{transform:rotateY(-8deg) rotateX(2deg) translateY(-8px)}}
@keyframes fc3{0%,100%{transform:rotateY(-15deg) rotateX(-3deg) translateY(0)}50%{transform:rotateY(-15deg) rotateX(-3deg) translateY(-10px)}}
.fc-icon{font-size:2.5rem;margin-bottom:.75rem}
.fc-name{font-family:'Syne',sans-serif;font-size:.9rem;font-weight:700;margin-bottom:.3rem}
.fc-price{font-size:.85rem;color:var(--cyan);font-weight:700}
.fc-badge{
  display:inline-block;font-size:.6rem;font-weight:700;letter-spacing:.1em;
  text-transform:uppercase;background:rgba(0,212,255,.12);color:var(--cyan);
  padding:.2rem .5rem;border-radius:4px;margin-bottom:.6rem
}

/* marquee */
.marquee-section{
  overflow:hidden;padding:.9rem 0;
  background:linear-gradient(90deg,var(--bg),var(--bg2),var(--bg));
  border-top:1px solid var(--border);border-bottom:1px solid var(--border)
}
.marquee-track{display:flex;gap:2.5rem;width:max-content;animation:marq 22s linear infinite}
.mi{
  display:flex;align-items:center;gap:.7rem;font-size:.72rem;
  font-weight:700;letter-spacing:.12em;text-transform:uppercase;
  color:var(--muted);white-space:nowrap
}
.mdot{width:4px;height:4px;background:var(--cyan);border-radius:50%}
@keyframes marq{to{transform:translateX(-50%)}}

/* categories */
.cats-section{padding:5rem 2.5rem}
.cats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.25rem;margin-top:3rem}
.cat-card{
  background:var(--card);backdrop-filter:blur(20px);
  border:1px solid var(--border);border-radius:var(--r16);
  padding:2.5rem 1.75rem;cursor:pointer;
  transition:all .3s cubic-bezier(.4,0,.2,1);
  transform-style:preserve-3d;position:relative;overflow:hidden
}
.cat-card::before{
  content:'';position:absolute;inset:0;border-radius:var(--r16);
  background:linear-gradient(135deg,var(--glow),transparent);
  opacity:0;transition:opacity .3s
}
.cat-card:hover{transform:translateY(-6px);border-color:var(--border2);box-shadow:0 20px 40px rgba(0,0,0,.3)}
.cat-card:hover::before{opacity:1}
.cat-icon{font-size:2.5rem;margin-bottom:1.25rem;display:block}
.cat-name{font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:700;margin-bottom:.4rem}
.cat-count{font-size:.82rem;color:var(--muted);font-weight:400}
.cat-arrow{
  position:absolute;top:1.5rem;right:1.5rem;width:28px;height:28px;
  border:1px solid var(--border2);border-radius:50%;display:flex;
  align-items:center;justify-content:center;font-size:.7rem;color:var(--muted);
  transition:all .3s
}
.cat-card:hover .cat-arrow{background:var(--cyan);border-color:var(--cyan);color:#000;transform:rotate(45deg)}

/* product grid */
.products-section{padding:5rem 2.5rem;background:var(--bg2)}
.prod-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem}
.prod-card{
  background:var(--card);backdrop-filter:blur(20px);
  border:1px solid var(--border);border-radius:var(--r16);
  overflow:hidden;cursor:pointer;
  transition:all .35s cubic-bezier(.4,0,.2,1);
  transform-style:preserve-3d;will-change:transform;
  position:relative
}
.prod-card::after{
  content:'';position:absolute;inset:-1px;border-radius:var(--r16);
  background:linear-gradient(135deg,rgba(0,212,255,.25),transparent 50%,rgba(0,255,209,.15));
  z-index:0;opacity:0;transition:opacity .3s;pointer-events:none
}
.prod-card:hover{box-shadow:0 25px 50px rgba(0,0,0,.4);z-index:2}
.prod-card:hover::after{opacity:1}
.prod-img{
  width:100%;height:200px;display:flex;align-items:center;justify-content:center;
  font-size:5rem;position:relative;overflow:hidden
}
.prod-img-inner{transition:transform .5s cubic-bezier(.4,0,.2,1)}
.prod-card:hover .prod-img-inner{transform:scale(1.08)}
.prod-body{padding:1.25rem;position:relative;z-index:1}
.prod-meta{display:flex;align-items:center;justify-content:space-between;margin-bottom:.6rem}
.prod-cat{font-size:.65rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
.prod-name{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;margin-bottom:.35rem;line-height:1.25}
.prod-rating{display:flex;align-items:center;gap:.35rem;font-size:.75rem;color:var(--muted);margin-bottom:.85rem}
.stars{color:var(--cyan);letter-spacing:.06em;font-size:.7rem}
.prod-footer{display:flex;align-items:center;justify-content:space-between}
.prod-price{font-family:'Syne',sans-serif;font-size:1.3rem;font-weight:800;color:var(--text)}
.prod-price sup{font-size:.8rem;vertical-align:super}
.add-btn{
  background:linear-gradient(135deg,var(--cyan),var(--mint));
  border:none;color:#000;font-weight:700;font-size:.75rem;
  padding:.5rem 1.1rem;border-radius:var(--r8);cursor:pointer;
  transition:all .2s;letter-spacing:.04em
}
.add-btn:hover{opacity:.85;transform:scale(1.05)}
.wishlist-btn{
  position:absolute;top:1rem;right:1rem;background:rgba(3,7,18,.7);
  border:1px solid var(--border);width:32px;height:32px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;font-size:.85rem;transition:all .2s;z-index:2;color:var(--muted)
}
.wishlist-btn:hover{border-color:var(--cyan);background:var(--glow);color:var(--cyan)}
.wishlist-btn.active{background:rgba(0,212,255,.15);border-color:var(--cyan);color:var(--cyan)}

/* filter bar */
.filter-bar{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-top:2.5rem}
.filter-btn{
  background:none;border:1px solid var(--border);color:var(--muted);
  font-family:'Manrope',sans-serif;font-size:.78rem;font-weight:600;
  letter-spacing:.06em;padding:.5rem 1.1rem;border-radius:20px;
  cursor:pointer;transition:all .2s;text-transform:uppercase
}
.filter-btn:hover,.filter-btn.active{
  background:linear-gradient(135deg,var(--cyan),var(--mint));
  border-color:transparent;color:#000
}

/* NEW arrivals strip */
.new-strip{padding:5rem 2.5rem}
.horiz-scroll{
  display:flex;gap:1.25rem;overflow-x:auto;padding:1rem 0 1.5rem;
  -ms-overflow-style:none;scrollbar-width:none;margin-top:2.5rem
}
.horiz-scroll::-webkit-scrollbar{display:none}
.strip-card{
  flex-shrink:0;width:220px;background:var(--card);backdrop-filter:blur(20px);
  border:1px solid var(--border);border-radius:var(--r16);
  overflow:hidden;cursor:pointer;transition:all .3s
}
.strip-card:hover{border-color:var(--border2);transform:translateY(-5px)}
.strip-img{height:160px;display:flex;align-items:center;justify-content:center;font-size:4rem}
.strip-body{padding:1rem}
.strip-name{font-family:'Syne',sans-serif;font-size:.9rem;font-weight:700;margin-bottom:.3rem}
.strip-price{font-size:.85rem;color:var(--cyan);font-weight:700}

/* stats strip */
.stats-bar{
  padding:3rem 2.5rem;background:var(--bg3);
  border-top:1px solid var(--border);border-bottom:1px solid var(--border)
}
.stats-inner{display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;max-width:960px;margin:0 auto;text-align:center}
.stat-val{font-family:'Syne',sans-serif;font-size:2.8rem;font-weight:800;line-height:1;background:linear-gradient(135deg,var(--cyan),var(--mint));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.stat-lbl{font-size:.75rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-top:.35rem}

/* banner */
.drop-banner{
  margin:0 2.5rem;border-radius:var(--r24);overflow:hidden;
  position:relative;padding:4rem 4rem;
  background:linear-gradient(135deg,rgba(0,212,255,.08),rgba(0,255,209,.05));
  border:1px solid var(--border2)
}
.drop-banner::before{
  content:'';position:absolute;inset:0;
  background:url("data:image/svg+xml,%3Csvg width='40' height='40' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='1' cy='1' r='1' fill='rgba(0,212,255,0.08)'/%3E%3C/svg%3E");
}
.drop-banner-inner{position:relative;z-index:1;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:2rem}
.drop-title{font-family:'Syne',sans-serif;font-size:clamp(2rem,5vw,4rem);font-weight:800;line-height:1;letter-spacing:-.02em}
.drop-count{
  display:flex;gap:1rem;align-items:center;flex-wrap:wrap
}
.count-box{background:rgba(3,7,18,.6);border:1px solid var(--border2);border-radius:var(--r12);padding:.75rem 1.25rem;text-align:center;min-width:70px}
.count-num{font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;color:var(--cyan);line-height:1}
.count-lbl{font-size:.6rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}

/* testimonials */
.testi-section{padding:5rem 2.5rem}
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-top:3rem}
.testi-card{
  background:var(--card);backdrop-filter:blur(20px);
  border:1px solid var(--border);border-radius:var(--r16);
  padding:2rem;transition:all .3s
}
.testi-card:hover{border-color:var(--border2);transform:translateY(-4px)}
.testi-stars{color:var(--cyan);font-size:.8rem;margin-bottom:.85rem;letter-spacing:.08em}
.testi-quote{font-size:.9rem;line-height:1.75;color:var(--text);font-weight:400;margin-bottom:1.5rem}
.testi-author{display:flex;align-items:center;gap:.75rem}
.testi-av{
  width:36px;height:36px;border-radius:var(--r8);display:flex;
  align-items:center;justify-content:center;font-size:.72rem;font-weight:700;
  flex-shrink:0;background:linear-gradient(135deg,var(--cyan),var(--mint));color:#000
}
.testi-name{font-size:.85rem;font-weight:700}
.testi-role{font-size:.72rem;color:var(--muted)}

/* features strip */
.feats-strip{
  padding:4rem 2.5rem;background:var(--bg2);
  border-top:1px solid var(--border)
}
.feats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;margin-top:2.5rem}
.feat-item{display:flex;align-items:flex-start;gap:1rem}
.feat-ico{
  width:44px;height:44px;flex-shrink:0;border-radius:var(--r8);
  background:var(--glow);border:1px solid var(--border2);
  display:flex;align-items:center;justify-content:center;font-size:1.1rem
}
.feat-title{font-size:.9rem;font-weight:700;margin-bottom:.35rem}
.feat-desc{font-size:.8rem;color:var(--muted);line-height:1.6}

/* newsletter */
.nl-section{padding:5rem 2.5rem;text-align:center}
.nl-inner{max-width:560px;margin:0 auto}
.nl-form{display:flex;gap:.75rem;margin-top:2rem}
.nl-form input{flex:1;background:rgba(10,22,40,.7);border:1px solid var(--border2);color:var(--text);font-family:'Manrope',sans-serif;font-size:.9rem;padding:.85rem 1rem;border-radius:var(--r12);outline:none;transition:border-color .2s}
.nl-form input:focus{border-color:var(--cyan)}
.nl-form input::placeholder{color:var(--muted2)}
.nl-form button{background:linear-gradient(135deg,var(--cyan),var(--mint));border:none;color:#000;font-weight:700;font-size:.85rem;padding:.85rem 1.75rem;border-radius:var(--r12);cursor:pointer;white-space:nowrap;transition:all .2s}
.nl-form button:hover{opacity:.85;transform:translateY(-1px)}

/* CTA band */
.cta-band{
  margin:0 2.5rem 4rem;border-radius:var(--r24);
  background:linear-gradient(135deg,var(--cyan),var(--mint));
  padding:4rem;display:flex;align-items:center;justify-content:space-between;
  gap:2rem;flex-wrap:wrap
}
.cta-band h2{font-family:'Syne',sans-serif;font-size:clamp(2rem,4vw,3rem);font-weight:800;color:#000;line-height:1;letter-spacing:-.02em;max-width:500px}
.btn-dark-cta{background:#000;border:none;color:var(--cyan);font-family:'Manrope',sans-serif;font-weight:800;font-size:.88rem;letter-spacing:.04em;padding:1rem 2.25rem;border-radius:var(--r12);cursor:pointer;transition:all .2s;white-space:nowrap}
.btn-dark-cta:hover{background:#0a1628;transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,.3)}

/* ── FOOTER ── */
footer{background:var(--bg2);border-top:1px solid var(--border)}
.footer-top{padding:3.5rem 2.5rem;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem;max-width:1240px;margin:0 auto}
.footer-brand .logo{font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800;background:linear-gradient(90deg,var(--cyan),var(--mint));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:.75rem}
.footer-brand p{font-size:.83rem;color:var(--muted);line-height:1.7;max-width:240px}
.footer-socials{display:flex;gap:.6rem;margin-top:1.25rem}
.fsoc{width:34px;height:34px;border:1px solid var(--border2);border-radius:var(--r8);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:.8rem;color:var(--muted);transition:all .2s;background:none}
.fsoc:hover{border-color:var(--cyan);color:var(--cyan);background:var(--glow)}
.footer-col h4{font-size:.68rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--muted2);margin-bottom:1.1rem}
.footer-col ul{list-style:none;display:flex;flex-direction:column;gap:.55rem}
.footer-col ul li button{background:none;border:none;color:var(--muted);font-family:'Manrope',sans-serif;font-size:.83rem;cursor:pointer;transition:color .2s;padding:0;text-align:left}
.footer-col ul li button:hover{color:var(--cyan)}
.footer-bot{padding:1.25rem 2.5rem;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem}
.footer-bot p,.footer-bot button{font-size:.75rem;color:var(--muted2);background:none;border:none;cursor:pointer;font-family:'Manrope',sans-serif;transition:color .2s}
.footer-bot button:hover{color:var(--muted)}
.footer-bot-links{display:flex;gap:1.5rem}

/* ── SHOP PAGE ── */
.shop-hero{padding:4.5rem 2.5rem 2.5rem;border-bottom:1px solid var(--border)}
.shop-toolbar{display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-top:1.5rem}
.sort-select{background:rgba(10,22,40,.8);border:1px solid var(--border2);color:var(--text);font-family:'Manrope',sans-serif;font-size:.82rem;padding:.5rem 1rem;border-radius:var(--r8);outline:none;cursor:pointer}
.shop-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.25rem;padding:3rem 2.5rem;max-width:1440px;margin:0 auto}
.result-count{font-size:.82rem;color:var(--muted);margin-left:auto;display:flex;align-items:center}

/* ── NEW IN PAGE ── */
.newin-hero{
  padding:5rem 2.5rem 3rem;background:var(--bg2);
  position:relative;overflow:hidden
}
.newin-grid{display:grid;grid-template-columns:1fr 2fr;gap:2rem;padding:3rem 2.5rem;max-width:1240px;margin:0 auto}
.newin-main-card{
  border-radius:var(--r24);overflow:hidden;
  background:var(--card);border:1px solid var(--border2);
  padding:3rem;position:relative
}
.newin-main-icon{font-size:8rem;text-align:center;margin:2rem 0;display:block}
.newin-side{display:flex;flex-direction:column;gap:1.25rem}
.newin-side-card{
  border-radius:var(--r16);background:var(--card);border:1px solid var(--border);
  padding:1.5rem;display:flex;align-items:center;gap:1.25rem;cursor:pointer;
  transition:all .3s
}
.newin-side-card:hover{border-color:var(--border2);transform:translateX(6px)}
.newin-side-icon{font-size:2.5rem;flex-shrink:0}
.newin-side-info h3{font-family:'Syne',sans-serif;font-size:.95rem;font-weight:700;margin-bottom:.3rem}
.newin-side-info p{font-size:.8rem;color:var(--muted)}

/* ── FEATURES PAGE ── */
.features-page{padding:5rem 2.5rem}
.feats-big-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.25rem;margin-top:3rem}
.feat-big-card{
  background:var(--card);backdrop-filter:blur(20px);
  border:1px solid var(--border);border-radius:var(--r16);
  padding:2.5rem;cursor:default;transition:all .3s;
  position:relative;overflow:hidden
}
.feat-big-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--cyan),var(--mint));
  transform:scaleX(0);transform-origin:left;transition:transform .4s
}
.feat-big-card:hover{border-color:var(--border2);transform:translateY(-4px)}
.feat-big-card:hover::before{transform:scaleX(1)}
.feat-big-icon{font-size:2.2rem;margin-bottom:1.5rem;display:block}
.feat-big-title{font-family:'Syne',sans-serif;font-size:1.15rem;font-weight:700;margin-bottom:.65rem}
.feat-big-desc{font-size:.88rem;color:var(--muted);line-height:1.75}
.security-badges{display:flex;flex-wrap:wrap;gap:.75rem;margin-top:3.5rem}
.sec-badge{background:var(--card);border:1px solid var(--border2);border-radius:var(--r8);padding:.6rem 1.1rem;font-size:.75rem;font-weight:700;color:var(--text);display:flex;align-items:center;gap:.5rem}

/* ── AUTH PAGES ── */
.auth-page{min-height:calc(100vh - 70px);display:flex}
.auth-left{
  flex:1;background:linear-gradient(135deg,var(--bg2),var(--bg3));
  padding:4rem;display:flex;flex-direction:column;justify-content:center;
  position:relative;overflow:hidden;border-right:1px solid var(--border)
}
.auth-left-orb{
  position:absolute;top:-20%;right:-20%;width:400px;height:400px;
  background:radial-gradient(circle,rgba(0,212,255,.08) 0%,transparent 65%);
  pointer-events:none;filter:blur(30px)
}
.auth-left h2{font-family:'Syne',sans-serif;font-size:clamp(2.5rem,5vw,4rem);font-weight:800;line-height:.95;letter-spacing:-.02em;margin-bottom:1.5rem}
.auth-perks{display:flex;flex-direction:column;gap:.85rem;margin-top:2.5rem}
.auth-perk{display:flex;align-items:center;gap:.75rem;font-size:.88rem;color:var(--muted)}
.auth-perk-ico{width:20px;height:20px;background:linear-gradient(135deg,var(--cyan),var(--mint));border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.55rem;color:#000;flex-shrink:0}
.auth-right{width:480px;flex-shrink:0;padding:4rem;display:flex;flex-direction:column;justify-content:center;overflow-y:auto}
.auth-right h3{font-family:'Syne',sans-serif;font-size:1.75rem;font-weight:800;margin-bottom:.4rem;letter-spacing:-.02em}
.auth-sub{font-size:.88rem;color:var(--muted);margin-bottom:2.25rem}
.auth-divider{display:flex;align-items:center;gap:1rem;margin:1.5rem 0}
.auth-divider::before,.auth-divider::after{content:'';flex:1;height:1px;background:var(--border2)}
.auth-divider span{font-size:.72rem;color:var(--muted2);font-weight:700;letter-spacing:.1em;text-transform:uppercase;white-space:nowrap}
.social-btn{
  width:100%;background:rgba(10,22,40,.8);border:1px solid var(--border2);
  color:var(--text);font-family:'Manrope',sans-serif;font-size:.85rem;font-weight:500;
  padding:.8rem;border-radius:var(--r8);cursor:pointer;margin-bottom:.6rem;
  display:flex;align-items:center;justify-content:center;gap:.75rem;
  transition:all .2s
}
.social-btn:hover{border-color:var(--cyan);background:var(--glow)}
.auth-switch{font-size:.83rem;color:var(--muted);text-align:center;margin-top:1.5rem}
.auth-switch button{background:none;border:none;color:var(--cyan);font-family:'Manrope',sans-serif;font-size:.83rem;cursor:pointer;font-weight:700;text-decoration:underline}
.pw-strength{height:3px;background:var(--bg4);border-radius:2px;margin-top:.5rem;overflow:hidden}
.pw-bar{height:100%;border-radius:2px;transition:width .3s,background .3s}
.terms-note{font-size:.72rem;color:var(--muted2);text-align:center;margin-top:1rem;line-height:1.6}
.terms-note a{color:var(--muted);text-decoration:underline}

/* ── SETTINGS PAGE ── */
.settings-page{padding:3rem 2.5rem;max-width:1100px;margin:0 auto}
.settings-grid{display:grid;grid-template-columns:220px 1fr;gap:2rem;margin-top:2rem}
.settings-nav{display:flex;flex-direction:column;gap:.2rem}
.snav-item{
  background:none;border:none;color:var(--muted);
  font-family:'Manrope',sans-serif;font-size:.83rem;font-weight:500;
  text-align:left;padding:.65rem .9rem;border-radius:var(--r8);
  cursor:pointer;display:flex;align-items:center;gap:.65rem;transition:all .2s
}
.snav-item:hover{background:rgba(0,212,255,.06);color:var(--text)}
.snav-item.active{background:rgba(0,212,255,.1);color:var(--cyan)}
.snav-item.active .snav-icon{color:var(--cyan)}
.snav-icon{font-size:.9rem;width:18px;text-align:center}
.sp{background:var(--card);backdrop-filter:blur(20px);border:1px solid var(--border);border-radius:var(--r16);padding:2rem;display:none}
.sp.active{display:block;animation:pgIn .3s ease}
.sp h3{font-family:'Syne',sans-serif;font-size:1.25rem;font-weight:700;margin-bottom:.3rem}
.sp>.sp-sub{font-size:.85rem;color:var(--muted);margin-bottom:2rem}
.sp-row{display:flex;align-items:center;justify-content:space-between;padding:1.1rem 0;border-bottom:1px solid var(--border);gap:2rem}
.sp-row:last-child{border-bottom:none}
.sp-row-info h4{font-size:.9rem;font-weight:700;margin-bottom:.2rem}
.sp-row-info p{font-size:.78rem;color:var(--muted)}
.sp-row-info .hint{color:var(--cyan);font-size:.72rem}
.toggle-wrap{display:flex;align-items:center;gap:.65rem}
.tog-track{
  width:42px;height:22px;background:var(--bg4);border:1px solid var(--border2);
  border-radius:11px;position:relative;cursor:pointer;transition:background .2s
}
.tog-track.on{background:linear-gradient(90deg,var(--cyan),var(--mint));border-color:transparent}
.tog-thumb{width:16px;height:16px;background:#fff;border-radius:50%;position:absolute;top:2px;left:2px;transition:transform .2s}
.tog-track.on .tog-thumb{transform:translateX(20px)}
.tog-label{font-size:.82rem;color:var(--muted)}
.plan-card{border:1px solid var(--border2);border-radius:var(--r12);padding:1.5rem;margin-bottom:1.5rem;background:rgba(0,212,255,.03);display:flex;align-items:center;justify-content:space-between;gap:1rem}
.plan-card h4{font-size:1rem;font-weight:700;margin-bottom:.25rem}
.plan-card p{font-size:.82rem;color:var(--muted)}
.usage-wrap{margin-top:.75rem}
.usage-labels{display:flex;justify-content:space-between;font-size:.72rem;color:var(--muted);margin-bottom:.35rem}
.usage-bar{height:4px;background:var(--bg4);border-radius:2px;overflow:hidden}
.usage-fill{height:100%;background:linear-gradient(90deg,var(--cyan),var(--mint));border-radius:2px}
.usage-fill.warn{background:linear-gradient(90deg,#FF8C42,#FF6B35)}
.billing-table{width:100%;border-collapse:collapse;margin-top:1.25rem}
.billing-table th{text-align:left;font-size:.66rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted2);padding:.6rem .75rem;border-bottom:1px solid var(--border2)}
.billing-table td{padding:.7rem .75rem;font-size:.83rem;border-bottom:1px solid var(--border);color:var(--muted)}
.billing-table td:first-child{color:var(--text)}
.billing-table tr:hover td{background:rgba(0,212,255,.02)}
.api-display{flex:1;background:var(--bg4);border:1px solid var(--border2);padding:.7rem 1rem;border-radius:var(--r8);font-family:monospace;font-size:.8rem;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.copy-btn{background:rgba(0,212,255,.1);border:1px solid var(--border2);color:var(--cyan);padding:.6rem .9rem;cursor:pointer;font-size:.75rem;border-radius:var(--r8);font-family:'Manrope',sans-serif;transition:all .2s;white-space:nowrap}
.copy-btn:hover{background:rgba(0,212,255,.2)}
.team-row{display:flex;align-items:center;gap:1rem;padding:.85rem 0;border-bottom:1px solid var(--border)}
.team-row:last-child{border-bottom:none}
.team-av{width:36px;height:36px;border-radius:var(--r8);display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:700;flex-shrink:0}
.team-info{flex:1}
.team-info h4{font-size:.88rem;font-weight:700}
.team-info p{font-size:.75rem;color:var(--muted)}
.role-sel{background:var(--bg4);border:1px solid var(--border2);color:var(--text);font-size:.75rem;padding:.3rem .6rem;border-radius:var(--r8);cursor:pointer;font-family:'Manrope',sans-serif;outline:none}
.sp-save{display:flex;gap:.75rem;margin-top:2rem}

/* NOTIFICATION */
.notif{
  position:fixed;top:80px;right:1.5rem;z-index:2000;
  background:rgba(6,15,31,.95);backdrop-filter:blur(20px);
  border:1px solid var(--cyan);border-radius:var(--r12);
  padding:.85rem 1.25rem;font-size:.84rem;font-weight:600;
  color:var(--cyan);transform:translateX(120%);transition:transform .35s cubic-bezier(.4,0,.2,1);
  display:flex;align-items:center;gap:.6rem;max-width:300px
}
.notif.show{transform:translateX(0)}
.notif-d{width:8px;height:8px;background:var(--cyan);border-radius:50%;flex-shrink:0;animation:pulse 1.5s ease-in-out infinite}

/* CART SIDEBAR */
.cart-overlay{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:1500;opacity:0;pointer-events:none;transition:opacity .3s}
.cart-overlay.open{opacity:1;pointer-events:all}
.cart-sidebar{
  position:fixed;top:0;right:0;bottom:0;width:380px;
  background:rgba(6,15,31,.97);backdrop-filter:blur(30px);
  border-left:1px solid var(--border2);z-index:1501;
  transform:translateX(100%);transition:transform .4s cubic-bezier(.4,0,.2,1);
  display:flex;flex-direction:column;padding:2rem
}
.cart-sidebar.open{transform:translateX(0)}
.cart-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem}
.cart-header h3{font-family:'Syne',sans-serif;font-size:1.2rem;font-weight:800}
.cart-close{background:none;border:1px solid var(--border2);color:var(--muted);width:32px;height:32px;border-radius:var(--r8);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s}
.cart-close:hover{border-color:var(--cyan);color:var(--cyan)}
.cart-items{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:1rem}
.cart-item{display:flex;align-items:center;gap:1rem;padding:1rem;background:rgba(10,22,40,.7);border:1px solid var(--border);border-radius:var(--r12)}
.cart-item-ico{font-size:2rem;width:52px;text-align:center;flex-shrink:0}
.cart-item-info{flex:1}
.cart-item-info h4{font-size:.88rem;font-weight:700;margin-bottom:.25rem}
.cart-item-price{font-size:.82rem;color:var(--cyan);font-weight:700}
.cart-remove{background:none;border:none;color:var(--muted);cursor:pointer;font-size:.9rem;transition:color .2s;padding:.25rem}
.cart-remove:hover{color:var(--red,#FF4757)}
.cart-footer{border-top:1px solid var(--border);padding-top:1.5rem;margin-top:1rem}
.cart-total{display:flex;justify-content:space-between;margin-bottom:1.25rem}
.cart-total span:first-child{font-size:.82rem;color:var(--muted)}
.cart-total span:last-child{font-family:'Syne',sans-serif;font-size:1.2rem;font-weight:800;color:var(--text)}
.cart-empty{text-align:center;padding:3rem 1rem;color:var(--muted)}
.cart-empty .ei{font-size:3rem;margin-bottom:1rem}

/* COOKIE */
.cookie{
  position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%) translateY(100px);
  z-index:1900;background:rgba(6,15,31,.95);backdrop-filter:blur(20px);
  border:1px solid var(--border2);border-radius:var(--r12);
  padding:1.1rem 1.5rem;display:flex;align-items:center;gap:1.25rem;flex-wrap:wrap;
  max-width:640px;width:calc(100% - 3rem);transition:transform .4s cubic-bezier(.4,0,.2,1)
}
.cookie.show{transform:translateX(-50%) translateY(0)}
.cookie p{font-size:.8rem;color:var(--muted);flex:1;line-height:1.6}
.cookie a{color:var(--cyan);text-decoration:none}
.cookie-btns{display:flex;gap:.6rem}
.cbtn-a{background:linear-gradient(135deg,var(--cyan),var(--mint));border:none;color:#000;font-weight:700;font-size:.75rem;padding:.45rem 1rem;border-radius:var(--r8);cursor:pointer}
.cbtn-d{background:none;border:1px solid var(--border2);color:var(--muted);font-size:.75rem;padding:.45rem 1rem;border-radius:var(--r8);cursor:pointer;transition:all .2s}
.cbtn-d:hover{border-color:var(--muted)}

/* LIVE CHAT */
.float-chat{
  position:fixed;bottom:2rem;right:2rem;z-index:900;
  background:linear-gradient(135deg,var(--cyan),var(--mint));
  color:#000;border:none;width:50px;height:50px;border-radius:50%;
  cursor:pointer;display:flex;align-items:center;justify-content:center;
  font-size:1.2rem;box-shadow:0 4px 20px rgba(0,212,255,.3);
  transition:all .25s
}
.float-chat:hover{transform:scale(1.1);box-shadow:0 8px 30px rgba(0,212,255,.4)}
.chat-popup{
  position:fixed;bottom:6rem;right:2rem;z-index:900;
  background:rgba(6,15,31,.97);backdrop-filter:blur(20px);
  border:1px solid var(--border2);border-radius:var(--r16);
  width:280px;padding:1.5rem;display:none;
  box-shadow:0 20px 60px rgba(0,0,0,.4)
}
.chat-popup.open{display:block;animation:pgIn .25s ease}
.chat-popup h4{font-family:'Syne',sans-serif;font-size:.95rem;font-weight:700;margin-bottom:.4rem}
.chat-popup p{font-size:.8rem;color:var(--muted);margin-bottom:1rem;line-height:1.6}
.chat-row{display:flex;gap:.5rem}
.chat-row input{flex:1;background:var(--bg3);border:1px solid var(--border2);color:var(--text);padding:.6rem .8rem;border-radius:var(--r8);font-size:.82rem;outline:none;font-family:'Manrope',sans-serif}
.chat-row button{background:linear-gradient(135deg,var(--cyan),var(--mint));border:none;color:#000;padding:.6rem .9rem;cursor:pointer;border-radius:var(--r8);font-weight:700;font-size:.8rem}

@media(max-width:960px){
